<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>✨ K-pop 男爱豆测试 · 升级版</title>
    <!-- 现代字体 & 图标库 (Font Awesome 仅用于备用图标，不影响核心功能) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(145deg, #0b0710 0%, #1e1428 50%, #2c1a3a 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px;
            margin: 0;
            animation: bgShift 20s ease infinite alternate;
        }

        @keyframes bgShift {
            0% { background: linear-gradient(145deg, #0b0710, #1e1428, #2c1a3a); }
            100% { background: linear-gradient(225deg, #140e1a, #251c30, #311f41); }
        }

        #container {
            width: 100%;
            max-width: 480px;
            background: rgba(20, 12, 28, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 120, 200, 0.2);
            border-radius: 42px;
            padding: 28px 22px;
            box-shadow: 0 30px 50px -10px rgba(0,0,0,0.8), 0 0 0 1px rgba(255, 140, 210, 0.2) inset;
            transition: transform 0.3s ease;
            color: #fff;
        }

        #container:hover {
            transform: scale(1.01);
        }

        h2 {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #ffb6e6, #a8d8ff, #c5a0ff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 20px;
            text-shadow: 0 2px 5px rgba(255, 105, 180, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        h2 i {
            font-size: 1.8rem;
            color: #ff9fd0;
            filter: drop-shadow(0 0 5px #ff8fd6);
        }

        #progress {
            font-size: 1rem;
            font-weight: 600;
            background: rgba(255,255,255,0.06);
            display: inline-block;
            padding: 8px 20px;
            border-radius: 100px;
            margin-bottom: 20px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255,200,230,0.2);
            color: #ffc8e4;
        }

        /* 图片容器效果 */
        .image-wrapper {
            position: relative;
            width: 100%;
            border-radius: 28px;
            overflow: hidden;
            margin-bottom: 22px;
            box-shadow: 0 20px 30px -10px black;
            border: 2px solid rgba(255, 180, 220, 0.4);
            aspect-ratio: 1 / 1;
            background: #2a1a32; /* fallback */
        }

        #idolImage {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.3, 1);
        }

        .image-wrapper:hover #idolImage {
            transform: scale(1.03);
        }

        #question h3 {
            font-size: 1.7rem;
            font-weight: 700;
            line-height: 1.3;
            margin: 15px 0 20px;
            background: rgba(255,255,255,0.05);
            padding: 15px 18px;
            border-radius: 40px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255, 200, 240, 0.15);
            word-break: keep-all;
        }

        #answers {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 10px 0 5px;
        }

        .answer-btn {
            width: 100%;
            padding: 16px 18px;
            border: none;
            border-radius: 60px;
            background: rgba(35, 20, 40, 0.7);
            backdrop-filter: blur(10px);
            color: white;
            font-size: 1.2rem;
            font-weight: 600;
            letter-spacing: 0.3px;
            text-align: left;
            display: flex;
            align-items: center;
            gap: 16px;
            border: 1px solid rgba(255, 150, 210, 0.3);
            box-shadow: 0 6px 12px rgba(0,0,0,0.4);
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .answer-btn:before {
            content: "▹";
            font-size: 1.5rem;
            color: #ff95d6;
            transition: transform 0.2s;
        }

        .answer-btn:hover {
            background: rgba(255, 120, 200, 0.25);
            border-color: #ffb0e0;
            transform: translateX(8px);
            box-shadow: 0 10px 20px -5px #ff60c0;
        }

        .answer-btn:active {
            transform: scale(0.98) translateX(4px);
        }

        /* 结果页样式 */
        .result-card {
            text-align: center;
        }

        .result-image {
            width: 100%;
            border-radius: 32px;
            margin: 15px 0 20px;
            border: 3px solid #ffb0dc;
            box-shadow: 0 20px 30px #2f1430;
            aspect-ratio: 1/1;
            object-fit: cover;
            background: #2c1b30;
        }

        .result-type {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(145deg, #ffe0f0, #dbb8ff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin: 20px 0 30px;
            line-height: 1.3;
            padding: 0 5px;
        }

        .action-buttons {
            display: flex;
            flex-direction: column;
            gap: 14px;
            margin-top: 20px;
        }

        .primary-btn, .secondary-btn {
            padding: 16px 20px;
            border-radius: 50px;
            font-size: 1.3rem;
            font-weight: 700;
            border: none;
            background: rgba(255, 120, 200, 0.25);
            backdrop-filter: blur(10px);
            color: white;
            border: 1px solid rgba(255, 180, 230, 0.6);
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            box-shadow: 0 6px 14px rgba(180, 0, 120, 0.3);
        }

        .primary-btn {
            background: linear-gradient(145deg, #ff80c0, #c45c9c);
            border: none;
            color: #140e1a;
            font-weight: 800;
        }

        .primary-btn:hover {
            background: linear-gradient(145deg, #ff99d0, #d47ab0);
            transform: scale(1.02);
            box-shadow: 0 15px 25px -5px #ff60b0;
        }

        .secondary-btn:hover {
            background: rgba(255, 140, 210, 0.4);
            transform: translateY(-3px);
        }

        /* 复制提示 */
        .copy-toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(30, 15, 25, 0.9);
            backdrop-filter: blur(10px);
            padding: 14px 28px;
            border-radius: 60px;
            color: #ffd6f0;
            font-weight: 600;
            border: 1px solid #ffa0d0;
            box-shadow: 0 10px 25px #ff30a030;
            z-index: 1000;
            animation: fadeInUp 0.3s;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translate(-50%, 20px); }
            to { opacity: 1; transform: translate(-50%, 0); }
        }

        /* 移动端微调 */
        @media (max-width: 400px) {
            #container { padding: 20px 16px; }
            h2 { font-size: 1.8rem; }
            #question h3 { font-size: 1.4rem; }
            .answer-btn { font-size: 1rem; padding: 14px; }
            .result-type { font-size: 1.8rem; }
        }
    </style>
</head>
<body>
    <div id="container">
        <!-- 内容由js动态渲染 -->
    </div>

    <script>
        // ---------- 智能备用图片生成器 (SVG占位图) ----------
        window.getPlaceholderDataURI = function (text = 'K-pop') {
            const svg = `
                <svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400">
                    <rect width="400" height="400" fill="#2e1b35" />
                    <circle cx="200" cy="170" r="70" fill="#b95c9f" opacity="0.4" />
                    <circle cx="150" cy="150" r="30" fill="#ff95d6" opacity="0.7" />
                    <circle cx="260" cy="200" r="40" fill="#b39eff" opacity="0.5" />
                    <text x="200" y="280" font-size="36" font-family="Arial, sans-serif" font-weight="bold" text-anchor="middle" fill="#ffc0e0" filter="url(#glow)">${text}</text>
                    <defs>
                        <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                            <feGaussianBlur in="SourceAlpha" stdDeviation="6"/>
                            <feMerge>
                                <feMergeNode in="offsetblur" />
                                <feMergeNode in="SourceGraphic" />
                            </feMerge>
                        </filter>
                    </defs>
                </svg>
            `;
            return 'data:image/svg+xml,' + encodeURIComponent(svg);
        };

        // ---------- 题目数据 (原5题 + 新增1题) ----------
        const questions = [
            {
                img: "https://i.imgur.com/2yaf2wb.jpg",
                q: "如果你成为练习生，最喜欢做？",
                a: [
                    { text: "🔥 疯狂练舞到深夜", type: "A" },
                    { text: "🎧 写歌/制作混音带", type: "B" },
                    { text: "🍜 和成员们一起吃拉面", type: "C" }
                ]
            },
            {
                img: "https://i.imgur.com/Ql7zF4F.jpg",
                q: "别人第一眼通常会怎么形容你？",
                a: [
                    { text: "⚡ 气场强大 像队长", type: "A" },
                    { text: "🌙 神秘高冷 艺术家气质", type: "B" },
                    { text: "☀ 超亲切 像隔壁同学", type: "C" }
                ]
            },
            {
                img: "https://i.imgur.com/VL9E7sH.jpg",
                q: "你在舞台上的风格是？",
                a: [
                    { text: "🤘 爆发力刀群舞", type: "A" },
                    { text: "✨ 梦幻氛围 眼神杀", type: "B" },
                    { text: "💖 超多粉丝互动", type: "C" }
                ]
            },
            {
                img: "https://i.imgur.com/3WcKq9L.jpg",
                q: "团体旅行时你通常是？",
                a: [
                    { text: "📋 负责安排行程的人", type: "A" },
                    { text: "🚶 漫无目的 随性闲逛", type: "B" },
                    { text: "🍔 带路寻找当地美食", type: "C" }
                ]
            },
            {
                img: "https://i.imgur.com/6G4Hk4S.jpg",
                q: "成员心情不好，你会？",
                a: [
                    { text: "🗣️ 直接谈心 给建议", type: "A" },
                    { text: "🤫 静静陪在身边", type: "B" },
                    { text: "🎭 搞怪逗他笑", type: "C" }
                ]
            },
            {
                // 新增第6题 让测试更丰富
                img: "https://i.imgur.com/7kFpWbG.jpg",
                q: "如果获得音乐节目一位，你的反应？",
                a: [
                    { text: "💥 爆发式庆祝 大喊", type: "A" },
                    { text: "😢 哽咽 感动到说不出话", type: "B" },
                    { text: "🤪 对着镜头做鬼脸", type: "C" }
                ]
            }
        ];

        // 结果配置 (使用备用稳定大图，但依然加onerror)
        const resultTypes = {
            A: {
                name: "🔥 舞台ACE型爱豆",
                img: "https://i.imgur.com/mq4F9vP.jpg"
            },
            B: {
                name: "🌙 气质艺术家型爱豆",
                img: "https://i.imgur.com/VZK4KpE.jpg"
            },
            C: {
                name: "☀ 快乐小狗型爱豆",
                img: "https://i.imgur.com/9lY5KpT.jpg"
            }
        };

        // 状态变量
        let index = 0;
        let score = { A: 0, B: 0, C: 0 };

        // DOM 容器
        const container = document.getElementById('container');

        // ---------- 辅助: 渲染题目页 ----------
        function showQuestion() {
            const q = questions[index];
            const progressText = `${index + 1} / ${questions.length}`;

            // 生成备用文本 (用于占位图)
            const placeholderLabel = `Q${index + 1}`;

            // 构建answers html
            let answersHtml = '';
            q.a.forEach(ans => {
                answersHtml += `<button class="answer-btn" onclick="choose('${ans.type}')">${ans.text}</button>`;
            });

            const html = `
                <h2><i class="fas fa-star"></i> K-pop 男爱豆测试 <i class="fas fa-star"></i></h2>
                <div id="progress">${progressText}</div>
                <div class="image-wrapper">
                    <img id="idolImage" src="${q.img}" 
                         onerror="this.onerror=null; this.src=getPlaceholderDataURI('${placeholderLabel}');"
                         alt="kpop quiz image">
                </div>
                <div id="question">
                    <h3>${q.q}</h3>
                </div>
                <div id="answers">
                    ${answersHtml}
                </div>
            `;
            container.innerHTML = html;
        }

        // ---------- 选择答案 ----------
        window.choose = function(type) {
            score[type] += 1;
            index++;

            if (index < questions.length) {
                showQuestion();
            } else {
                showResult();
            }
        };

        // ---------- 判定结果 (平局按优先级 A > B > C) ----------
        function getResultType() {
            const { A, B, C } = score;
            // 优先级: A >= B 且 A >= C  → A
            if (A >= B && A >= C) return 'A';
            // B >= C 且 B > A (因为如果B>=A且A>=B则平局，已归A)
            if (B >= C && B > A) return 'B';
            // 其余情况归C
            return 'C';
        }

        // ---------- 显示结果页 + 再测/分享按钮 ----------
        function showResult() {
            const typeKey = getResultType();
            const result = resultTypes[typeKey];
            const resultName = result.name;
            const resultImg = result.img;

            const html = `
                <h2><i class="fas fa-crown"></i> 测试结果 <i class="fas fa-crown"></i></h2>
                <div class="image-wrapper">
                    <img class="result-image" src="${resultImg}" 
                         onerror="this.onerror=null; this.src=getPlaceholderDataURI('result');"
                         alt="result image">
                </div>
                <div class="result-type">${resultName}</div>
                <div class="action-buttons">
                    <button class="primary-btn" onclick="resetTest()"><i class="fas fa-rotate-right"></i> 再测一次</button>
                    <button class="secondary-btn" onclick="shareResult('${resultName}')"><i class="fas fa-share-alt"></i> 分享结果</button>
                </div>
            `;
            container.innerHTML = html;
        }

        // ---------- 重置测试 ----------
        window.resetTest = function() {
            index = 0;
            score = { A: 0, B: 0, C: 0 };
            showQuestion();
        };

        // ---------- 分享结果 (复制到剪贴板) ----------
        window.shareResult = function(resultName) {
            const text = `我刚刚测出的K-pop男爱豆类型是：${resultName} ✨ 快来测测你像谁～`;
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(() => {
                    showCopyToast('✅ 结果已复制到剪贴板！');
                }).catch(() => {
                    fallbackCopy(text);
                });
            } else {
                fallbackCopy(text);
            }
        };

        function fallbackCopy(text) {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
                showCopyToast('📋 复制成功（手动模式）');
            } catch (err) {
                alert('复制失败，您可以手动复制：' + text);
            }
            document.body.removeChild(textarea);
        }

        function showCopyToast(msg) {
            const toast = document.createElement('div');
            toast.className = 'copy-toast';
            toast.innerText = msg;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.remove();
            }, 2000);
        }

        // 启动测试
        showQuestion();

        // 额外优化：确保所有图片都有备用占位 (onerror已内联)
    </script>
</body>
</html>
